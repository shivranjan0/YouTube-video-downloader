    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.6",
    "cheerio": "^1.0.0-rc.12",
    "concurrently": "^9.1.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.513.0",
    "nodemailer": "^8.0.2",
    "ogl": "^1.0.11",
    "playwright": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
